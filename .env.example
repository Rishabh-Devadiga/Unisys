PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=postgres
# Optional: overrides PG* values
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# SMTP config for defaulter emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=edusysalert@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=edusysalert@gmail.com

# WebRTC TURN/ICE configuration
# Comma-separated TURN urls. Example: turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Cloudflare TURN API
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=

# Security
SESSION_SECRET=change_me_long_random
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_MAX=200
RATE_LIMIT_AUTH_MAX=20
TRUST_PROXY=false
